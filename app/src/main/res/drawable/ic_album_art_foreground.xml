 <vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="512"
    android:viewportHeight="512">
    <!-- Rule 2: Symbolism (The Record Spindle) -->
    <path
        android:fillColor="#F8FAFC"
        android:pathData="M 272,256 A 16,16 0 1,1 240,256 A 16,16 0 1,1 272,256" />

    <group
        android:pivotX="256"
        android:pivotY="256"
        android:rotation="135">

        <!-- Rule 5: Dynamic Energy (The Rising Chart) -->
        <!-- Track 1: Lower Ranks -->
        <path
            android:strokeColor="#4C1D95"
            android:strokeWidth="32"
            android:strokeLineCap="round"
            android:trimPathEnd="0.1492"
            android:pathData="M 304,256 A 48,48 0 1,1 208,256 A 48,48 0 1,1 304,256" />

        <!-- Track 2: Climbing the Chart -->
        <path
            android:strokeColor="#7C3AED"
            android:strokeWidth="32"
            android:strokeLineCap="round"
            android:trimPathEnd="0.3498"
            android:pathData="M 352,256 A 96,96 0 1,1 160,256 A 96,96 0 1,1 352,256" />

        <!-- Track 3: Top 10 -->
        <path
            android:strokeColor="#C026D3"
            android:strokeWidth="32"
            android:strokeLineCap="round"
            android:trimPathEnd="0.6499"
            android:pathData="M 400,256 A 144,144 0 1,1 112,256 A 144,144 0 1,1 400,256" />

        <!-- Rule 3 & 4: Purposeful Color & Distinctiveness -->
        <!-- Track 4: The Number 1 Spot -->
        <path
            android:strokeColor="#FF3366"
            android:strokeWidth="32"
            android:strokeLineCap="round"
            android:trimPathEnd="0.8994"
            android:pathData="M 448,256 A 192,192 0 1,1 64,256 A 192,192 0 1,1 448,256" />

    </group>
</vector>
